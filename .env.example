# JobScan environment variables
#
# Copy this file to .env (which is gitignored — never commit secrets):
#
#     cp .env.example .env
#     chmod 600 .env       # restrict to your user only
#
# Then fill in real values below. notify.mjs auto-loads .env at startup;
# you don't need to `source` it manually.
#
# Only required if you want to send email notifications. Without these,
# JobScan still produces data/jobscan-out.md and data/jobscan-out.html;
# only the Resend send path is disabled.

# Resend API key (https://resend.com → API Keys)
RESEND_API=

# Verified sender email — must match a domain you've verified in Resend.
# For development, Resend allows "onboarding@resend.dev".
SENDER_EMAIL=

# Default recipient when no --to= flag is passed. Comma-separate for multiple.
# Examples:
#   DEFAULT_RECIPIENT_EMAIL=you@gmail.com
#   DEFAULT_RECIPIENT_EMAIL=you@gmail.com,partner@gmail.com
DEFAULT_RECIPIENT_EMAIL=
